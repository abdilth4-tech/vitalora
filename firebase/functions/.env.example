# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Project ID (for reference)
FIREBASE_PROJECT_ID=vitalora-telemedicine

# Gemini Model (usually gemini-pro or gemini-1.5-pro)
GEMINI_MODEL=gemini-pro

# Rate limiting
RATE_LIMIT_REQUESTS_PER_HOUR=20

# CORS origin (for production, specify exact origin)
CORS_ORIGIN=*
