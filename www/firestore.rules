rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    //  DEV RULES — semua authenticated user bisa baca/tulis semua koleksi
    //  TODO: Ganti dengan production rules sebelum deploy ke publik
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
